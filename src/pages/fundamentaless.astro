---
import Site from '../layouts/Site.astro';
---

<Site
  title="FundamentaleSS | SUAyED"
  description="Libros electrónicos y recursos para médicos pasantes en servicio social. Facultad de Medicina UNAM."
>
  <section class="bg-[var(--color-unam-blue-dark)] relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-unam-gold)] to-[var(--color-unam-gold-light)]"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
    <div class="container-site py-16 md:py-20 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-6">
        <a href="/" class="hover:text-white/70 transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/70">FundamentaleSS</span>
      </nav>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/20 border border-purple-400/30 mb-4">
        <span class="text-xs font-semibold text-purple-300 tracking-wide uppercase">Servicio social · Médico Cirujano</span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        FundamentaleSS
      </h1>
      <p class="text-white/65 text-lg max-w-2xl leading-relaxed">
        Programa de fortalecimiento académico para médicos pasantes en servicio social de la licenciatura de Médico Cirujano, FacMed-UNAM.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-site">
      <div class="max-w-3xl">

        <!-- Alert importante -->
        <div class="rounded-[var(--radius-lg)] border border-amber-200 bg-amber-50 p-5 mb-10 flex gap-3">
          <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.232 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <div>
            <p class="text-sm font-semibold text-amber-800 mb-1">Importante</p>
            <p class="text-sm text-amber-700 leading-relaxed">
              FundamentaleSS está dirigido exclusivamente al alumnado en servicio social de la licenciatura de Médico Cirujano de la Facultad de Medicina UNAM.
            </p>
          </div>
        </div>

        <div class="rounded-[var(--radius-xl)] border border-[var(--color-border)] p-8 mb-8 bg-[var(--color-surface)]">
          <h2 class="text-xl font-bold text-[var(--color-text-base)] mb-3">¿Qué es FundamentaleSS?</h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            El Programa para el fortalecimiento académico del médico pasante y de apoyo a la calidad de su labor asistencial de la Facultad de Medicina se desarrolla a través de <strong class="text-[var(--color-text-base)]">tres líneas de acción</strong> orientadas a apoyar a los pasantes durante su año de servicio social.
          </p>
        </div>

        <h2 class="text-xl font-bold text-[var(--color-text-base)] mb-5">Líneas de acción</h2>
        <div class="space-y-4 mb-10">
          {[
            {
              num: '01',
              title: 'Libros electrónicos',
              desc: 'Recursos bibliográficos digitales especializados, disponibles en línea para consulta en cualquier momento durante el servicio social.',
            },
            {
              num: '02',
              title: 'Apoyo académico',
              desc: 'Materiales de orientación clínica y de atención primaria a la salud para fortalecer la práctica médica en el servicio social.',
            },
            {
              num: '03',
              title: 'Recursos de apoyo asistencial',
              desc: 'Herramientas y guías para mejorar la calidad de la atención médica en las sedes de servicio social.',
            },
          ].map((line) => (
            <div class="flex gap-4 p-5 rounded-[var(--radius-lg)] border border-[var(--color-border)]">
              <div class="w-10 h-10 rounded-full bg-[var(--color-unam-blue)] text-white flex items-center justify-center text-xs font-bold shrink-0">
                {line.num}
              </div>
              <div>
                <h3 class="font-bold text-[var(--color-text-base)] mb-1">{line.title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{line.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="rounded-[var(--radius-xl)] bg-[var(--color-unam-blue)] p-8 text-center">
          <h2 class="text-2xl font-extrabold text-white mb-3">Accede a los recursos</h2>
          <p class="text-white/70 mb-6 text-sm">Consulta los libros electrónicos y materiales de apoyo disponibles para tu servicio social.</p>
          <a
            href="https://suayed.facmed.unam.mx/index.php/fundamentaless/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--color-unam-gold)] text-[var(--color-unam-blue-dark)] font-bold text-sm hover:bg-[var(--color-unam-gold-dark)] transition-colors"
          >
            Ir a FundamentaleSS
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Site>
