---
import Site from '../layouts/Site.astro';

const lineas = [
  {
    num: '01',
    title: 'Libros electrónicos',
    desc: 'Recursos bibliográficos digitales especializados, disponibles en línea para consulta en cualquier momento durante el servicio social.',
  },
  {
    num: '02',
    title: 'Apoyo académico',
    desc: 'Materiales de orientación clínica y de atención primaria a la salud para fortalecer la práctica médica en el servicio social.',
  },
  {
    num: '03',
    title: 'Recursos de apoyo asistencial',
    desc: 'Herramientas y guías para mejorar la calidad de la atención médica en las sedes de servicio social.',
  },
];
---

<Site
  title="FundamentaleSS | SUAyED"
  description="Libros electrónicos y recursos para médicos pasantes en servicio social. Facultad de Medicina UNAM."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">FundamentaleSS</span>
      </nav>
      <p class="eyebrow mb-4">Servicio social · Médico Cirujano</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        FundamentaleSS
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        Programa de fortalecimiento académico para médicos pasantes en servicio social de la licenciatura de Médico Cirujano, Facultad de Medicina UNAM.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-[var(--color-surface)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20 lg:items-start">
      <div>
        <p class="eyebrow mb-5">¿Qué es?</p>
        <h2
          class="display text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-navy)] leading-[1.08] mb-6"
          style="font-optical-sizing: auto;"
        >
          Fortalecimiento para el pasante
        </h2>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75] mb-4">
          El Programa para el fortalecimiento académico del médico pasante y de apoyo a la calidad de su labor asistencial de la Facultad de Medicina se desarrolla a través de <strong class="text-[var(--color-navy)] font-semibold">tres líneas de acción</strong> orientadas a apoyar a los pasantes durante su año de servicio social.
        </p>
        <!-- Notice -->
        <div class="border border-[var(--color-border)] rounded-[var(--radius-md)] px-5 py-4 mb-8 bg-[var(--color-bg)]">
          <p class="text-[0.75rem] font-bold tracking-[0.08em] uppercase text-[var(--color-gold-dark)] mb-1">Importante</p>
          <p class="text-[0.875rem] text-[var(--color-text-mid)] leading-relaxed">
            FundamentaleSS está dirigido exclusivamente al alumnado en servicio social de la licenciatura de Médico Cirujano de la Facultad de Medicina UNAM.
          </p>
        </div>
        <a
          href="https://suayed.facmed.unam.mx/index.php/fundamentaless/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-navy)] text-[var(--color-bg)] text-sm font-semibold hover:bg-[var(--color-navy-mid)] transition-colors duration-150"
        >
          Ir a FundamentaleSS
          <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
      <div>
        <p class="eyebrow mb-5">Líneas de acción</p>
        <div class="border-t border-[var(--color-border)]">
          {lineas.map((line) => (
            <div class="grid grid-cols-[2.5rem_1fr] gap-4 py-6 border-b border-[var(--color-border)]">
              <span class="text-[0.625rem] font-bold tracking-[0.08em] text-[var(--color-gold-dark)] pt-0.5">{line.num}</span>
              <div>
                <h3 class="font-[family-name:var(--font-display)] font-semibold text-[0.9375rem] text-[var(--color-navy)] mb-1.5" style="font-optical-sizing: auto;">{line.title}</h3>
                <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">{line.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Site>
