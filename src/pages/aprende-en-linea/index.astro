---
import Site from '../../layouts/Site.astro';

const subpages = [
  {
    title: 'Comunidad PREMED',
    desc: 'Diagnóstico de conocimientos del bachillerato. Evalúa tu salud académica integral antes de iniciar la licenciatura.',
    href: '/aprende-en-linea/premed',
    tag: 'Aspirantes',
  },
  {
    title: 'Ponte en Líne@',
    desc: 'Tutorías, seminarios y recursos educativos para reforzar tu aprendizaje durante la licenciatura.',
    href: '/aprende-en-linea/ponte-en-linea',
    tag: 'Estudiantes',
  },
  {
    title: 'Asignaturas en línea (MOLIMOD)',
    desc: '32 optativas a distancia con contenidos innovadores. Disponibles en cualquier momento y desde cualquier lugar.',
    href: '/aprende-en-linea/asignaturas',
    tag: 'Estudiantes',
  },
  {
    title: 'Periodos intensivos',
    desc: 'Cursa asignaturas optativas en dos semanas de trabajo intenso. Para estudiantes de 1° a 4° año.',
    href: '/aprende-en-linea/periodos-intensivos',
    tag: 'Estudiantes',
  },
  {
    title: 'FundamentaleSS',
    desc: 'Libros electrónicos y recursos de apoyo para médicos pasantes en servicio social.',
    href: '/fundamentaless',
    tag: 'Servicio social',
  },
  {
    title: 'Logra tu Meta',
    desc: 'Exámenes de autoevaluación gratuitos para preparar el ENARM y orientarte hacia una especialidad.',
    href: '/logra-tu-meta/facultad',
    tag: 'Egresados',
  },
];
---

<Site
  title="Aprende en línea | SUAyED"
  description="Hub de programas educativos en línea de la Facultad de Medicina UNAM."
>
  <!-- Page hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">Aprende en línea</span>
      </nav>
      <p class="eyebrow mb-4">Oferta educativa</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        Aprende en línea
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        Programas y recursos digitales diseñados por la Facultad de Medicina de la UNAM para acompañarte en cada etapa de tu formación: desde antes de ingresar hasta la preparación para la especialidad.
      </p>
    </div>
  </section>

  <!-- Programs -->
  <section class="bg-[var(--color-surface)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="border-t border-[var(--color-border)]">
        {subpages.map((page) => (
          <a
            href={page.href}
            class="group grid grid-cols-1 md:grid-cols-[7rem_1fr_1.5rem] gap-3 md:gap-8 items-center py-6 border-b border-[var(--color-border)] hover:border-[var(--color-border-strong)] transition-colors duration-150"
          >
            <span class="text-[0.625rem] font-bold tracking-[0.1em] uppercase text-[var(--color-text-faint)] group-hover:text-[var(--color-gold-dark)] transition-colors leading-none">
              {page.tag}
            </span>
            <div>
              <h2
                class="font-[family-name:var(--font-display)] font-semibold text-[1.125rem] text-[var(--color-navy)] leading-snug mb-1"
                style="font-optical-sizing: auto;"
              >
                {page.title}
              </h2>
              <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">
                {page.desc}
              </p>
            </div>
            <svg class="hidden md:block w-3.5 h-3.5 text-[var(--color-text-faint)] group-hover:text-[var(--color-navy)] group-hover:translate-x-0.5 transition-all duration-150 shrink-0 justify-self-end" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Campus CTA -->
  <section class="bg-[var(--color-navy)] py-12">
    <div class="container-site flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="font-[family-name:var(--font-display)] font-semibold text-[1.25rem] text-[var(--color-bg)] leading-snug" style="font-optical-sizing: auto;">
          ¿Ya tienes acceso al campus virtual?
        </p>
        <p class="text-[0.8125rem] text-[oklch(74%_0.02_255)] mt-1">
          Usa tus credenciales de la Facultad de Medicina para ingresar directamente.
        </p>
      </div>
      <a
        href="https://campus.facmed.unam.mx"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--color-gold)] text-[var(--color-navy)] font-bold text-sm hover:bg-[var(--color-gold-dark)] transition-colors duration-150 shrink-0"
      >
        Ir al campus virtual
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </section>
</Site>
