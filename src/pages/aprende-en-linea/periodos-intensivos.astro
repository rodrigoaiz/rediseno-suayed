---
import Site from '../../layouts/Site.astro';
---

<Site
  title="Periodos intensivos | SUAyED"
  description="Cursa asignaturas optativas en periodos de dos semanas. Facultad de Medicina UNAM."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <a href="/aprende-en-linea" class="hover:text-[var(--color-navy)] transition-colors">Aprende en línea</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">Periodos intensivos</span>
      </nav>
      <p class="eyebrow mb-4">1° a 4° año · Médico Cirujano</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        Periodos intensivos
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        Aprovecha los periodos intersemestrales para cursar asignaturas optativas en modalidad intensiva, sin interrumpir tu ritmo regular de estudios.
      </p>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="bg-[var(--color-surface)] py-10 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row gap-8 sm:gap-0 sm:divide-x divide-[var(--color-border)]">
        {[
          { value: '2', unit: 'semanas', label: 'duración de cada periodo' },
          { value: '3–4', unit: 'hrs/día', label: 'dedicación diaria recomendada' },
          { value: '34', unit: 'horas', label: 'total a cubrir por asignatura' },
        ].map((s) => (
          <div class="sm:pr-12 sm:last:pr-0 sm:pl-12 sm:first:pl-0">
            <div class="flex items-baseline gap-1.5 mb-1">
              <span
                class="display tabular text-[clamp(2rem,4vw,2.75rem)] text-[var(--color-navy)] leading-none tracking-[-0.02em]"
                style="font-optical-sizing: auto;"
              >
                {s.value}
              </span>
              <span class="text-[0.875rem] font-semibold text-[var(--color-gold-dark)]">{s.unit}</span>
            </div>
            <div class="text-[0.75rem] text-[var(--color-text-faint)]">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-[var(--color-bg)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20 lg:items-start">
      <div>
        <p class="eyebrow mb-5">¿Cómo funcionan?</p>
        <h2
          class="display text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-navy)] leading-[1.08] mb-6"
          style="font-optical-sizing: auto;"
        >
          Dos semanas de trabajo concentrado
        </h2>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75] mb-4">
          Son periodos de <strong class="text-[var(--color-navy)] font-semibold">dos semanas de trabajo intenso</strong> en los que puedes cursar asignaturas optativas. Necesitas dedicar entre <strong class="text-[var(--color-navy)] font-semibold">3 y 4 horas diarias</strong> para estudiar los contenidos, realizar actividades de aprendizaje y cubrir las 34 horas reglamentarias.
        </p>
        <div class="border border-[var(--color-border)] rounded-[var(--radius-md)] px-5 py-4 mb-8 bg-[var(--color-surface)]">
          <p class="text-[0.75rem] font-bold tracking-[0.08em] uppercase text-[var(--color-gold-dark)] mb-1">¿Quién puede inscribirse?</p>
          <p class="text-[0.875rem] text-[var(--color-text-mid)] leading-relaxed">
            Estudiantes de <strong class="text-[var(--color-navy)] font-semibold">1° a 4° año</strong> de la licenciatura de Médico Cirujano. Las optativas MOLIMOD también están disponibles en periodos regulares.
          </p>
        </div>
        <a
          href="https://suayed.facmed.unam.mx/index.php/aprendeenlinea/intensivos/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-navy)] text-[var(--color-bg)] text-sm font-semibold hover:bg-[var(--color-navy-mid)] transition-colors duration-150"
        >
          Ver periodos disponibles
          <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
      <div class="space-y-0 border-t border-[var(--color-border)]">
        {[
          { label: '01', title: 'Modalidad a distancia', desc: 'Cursa desde cualquier lugar, sin necesidad de asistir presencialmente a la Facultad.' },
          { label: '02', title: 'Optativas MOLIMOD', desc: 'Las asignaturas disponibles en periodos intensivos forman parte del catálogo MOLIMOD.' },
          { label: '03', title: 'Actividades programadas', desc: 'Cada asignatura incluye actividades de aprendizaje calendarizadas para las dos semanas.' },
          { label: '04', title: 'Valor curricular', desc: 'Cuentan con créditos equivalentes a las optativas en periodo regular.' },
        ].map((feat) => (
          <div class="grid grid-cols-[2.5rem_1fr] gap-4 py-5 border-b border-[var(--color-border)]">
            <span class="text-[0.625rem] font-bold tracking-[0.08em] text-[var(--color-gold-dark)] pt-0.5">{feat.label}</span>
            <div>
              <h3 class="font-[family-name:var(--font-display)] font-semibold text-[0.9375rem] text-[var(--color-navy)] mb-1" style="font-optical-sizing: auto;">{feat.title}</h3>
              <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">{feat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Site>
