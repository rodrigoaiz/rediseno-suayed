---
import Site from '../../layouts/Site.astro';

const stats = [
  { value: '32', label: 'optativas MOLIMOD', sub: 'solo en modalidad a distancia' },
  { value: '70', label: 'optativas totales', sub: 'en el sistema de la Facultad' },
  { value: '3', label: 'en ambas modalidades', sub: 'presencial y a distancia' },
];
---

<Site
  title="Asignaturas modalidad en línea | SUAyED"
  description="32 asignaturas optativas MOLIMOD a distancia de la Facultad de Medicina UNAM."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <a href="/aprende-en-linea" class="hover:text-[var(--color-navy)] transition-colors">Aprende en línea</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">Asignaturas en línea</span>
      </nav>
      <p class="eyebrow mb-4">MOLIMOD · Para estudiantes</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        Asignaturas<br/>modalidad en línea
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        Optativas innovadoras a la vanguardia de la ciencia médica, disponibles completamente a distancia para estudiantes de Médico Cirujano.
      </p>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="bg-[var(--color-surface)] py-10 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row gap-8 sm:gap-0 sm:divide-x divide-[var(--color-border)]">
        {stats.map((s) => (
          <div class="sm:pr-12 sm:last:pr-0 sm:pl-12 sm:first:pl-0">
            <div
              class="display tabular text-[clamp(2rem,4vw,2.75rem)] text-[var(--color-navy)] leading-none mb-1 tracking-[-0.02em]"
              style="font-optical-sizing: auto;"
            >
              {s.value}
            </div>
            <div class="text-[0.8125rem] text-[var(--color-text-soft)] font-medium">{s.label}</div>
            <div class="text-[0.75rem] text-[var(--color-text-faint)] mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-[var(--color-bg)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20 lg:items-start">
      <div>
        <p class="eyebrow mb-5">¿Qué son?</p>
        <h2
          class="display text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-navy)] leading-[1.08] mb-6"
          style="font-optical-sizing: auto;"
        >
          Optativas de vanguardia a distancia
        </h2>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75] mb-4">
          Las optativas son asignaturas con contenidos complementarios a las obligatorias: mayor nivel de especificidad o temas producto de investigaciones recientes. Por ello cuentan con temas a profundidad, innovadores y a la vanguardia de la ciencia médica, socio-médica y humanística.
        </p>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75] mb-8">
          Contribuyen a la <strong class="text-[var(--color-navy)] font-semibold">formación integral del médico cirujano</strong>, expandiendo su visión más allá del currículo obligatorio.
        </p>
        <a
          href="https://suayed.facmed.unam.mx/index.php/aprendeenlinea/molimod/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-navy)] text-[var(--color-bg)] text-sm font-semibold hover:bg-[var(--color-navy-mid)] transition-colors duration-150"
        >
          Ver asignaturas disponibles
          <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
      <div class="space-y-0 border-t border-[var(--color-border)]">
        {[
          { label: '01', title: '100% a distancia', desc: 'Sin necesidad de asistir físicamente a la Facultad.' },
          { label: '02', title: 'Horario flexible', desc: 'Estudia a tu ritmo dentro del periodo académico.' },
          { label: '03', title: 'Contenido de vanguardia', desc: 'Temas actualizados con las últimas investigaciones en medicina.' },
          { label: '04', title: 'Valor curricular', desc: 'Créditos equivalentes a las optativas presenciales.' },
        ].map((feat) => (
          <div class="grid grid-cols-[2.5rem_1fr] gap-4 py-5 border-b border-[var(--color-border)]">
            <span class="text-[0.625rem] font-bold tracking-[0.08em] text-[var(--color-gold-dark)] pt-0.5">{feat.label}</span>
            <div>
              <h3 class="font-[family-name:var(--font-display)] font-semibold text-[0.9375rem] text-[var(--color-navy)] mb-1" style="font-optical-sizing: auto;">{feat.title}</h3>
              <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">{feat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Site>
