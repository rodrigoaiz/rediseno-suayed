---
import Site from '../layouts/Site.astro';

const docs = [
  {
    title: 'Lineamientos para el desarrollo del MOLIMOD',
    desc: 'Normativa que regula el funcionamiento y operación de las asignaturas optativas en modalidad a distancia.',
    icon: '📄',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Reglamento General de Inscripciones',
    desc: 'Normas generales para la inscripción y reinscripción de alumnos en la UNAM.',
    icon: '📋',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Estatuto General de la UNAM',
    desc: 'Marco normativo fundamental que rige la organización y funcionamiento de la Universidad.',
    icon: '🏛️',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Plan de Estudios de Medicina',
    desc: 'Estructura curricular y plan de estudios vigente de la licenciatura de Médico Cirujano.',
    icon: '📚',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
];
---

<Site
  title="Normatividad | SUAyED"
  description="Lineamientos, procedimientos y documentos normativos del SUAyED Facultad de Medicina UNAM."
>
  <section class="bg-[var(--color-unam-blue-dark)] relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-unam-gold)] to-[var(--color-unam-gold-light)]"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
    <div class="container-site py-16 md:py-20 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-6">
        <a href="/" class="hover:text-white/70 transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/70">Normatividad</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        Normatividad
      </h1>
      <p class="text-white/65 text-lg max-w-2xl leading-relaxed">
        Lineamientos, procedimientos y documentos normativos que rigen el funcionamiento del SUAyED y los programas educativos de la Facultad de Medicina UNAM.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-site">
      <div class="max-w-3xl">
        <!-- Intro -->
        <div class="rounded-[var(--radius-xl)] border border-[var(--color-border)] p-6 mb-10 flex gap-4 bg-[var(--color-surface)]">
          <div class="w-10 h-10 rounded-[var(--radius-md)] bg-[var(--color-unam-blue-light)] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[var(--color-unam-blue)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-[var(--color-text-base)] mb-1">Documentos de consulta y descarga</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Aquí encontrarás los lineamientos y procedimientos oficiales del SUAyED FM. Los documentos están disponibles en formato PDF para descarga directa.
            </p>
          </div>
        </div>

        <!-- Documents list -->
        <h2 class="text-lg font-bold text-[var(--color-text-base)] mb-5">Documentos disponibles</h2>
        <div class="space-y-3 mb-10">
          {docs.map((doc) => (
            <a
              href={doc.href}
              target="_blank"
              rel="noopener"
              class="group flex items-center gap-4 p-5 rounded-[var(--radius-lg)] border border-[var(--color-border)] hover:border-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)] transition-all duration-150"
            >
              <span class="text-2xl shrink-0">{doc.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-[var(--color-text-base)] group-hover:text-[var(--color-unam-blue)] transition-colors text-sm mb-0.5">{doc.title}</h3>
                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed truncate">{doc.desc}</p>
              </div>
              <div class="shrink-0 w-8 h-8 rounded-full bg-[var(--color-surface)] group-hover:bg-white flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-[var(--color-text-subtle)] group-hover:text-[var(--color-unam-blue)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              </div>
            </a>
          ))}
        </div>

        <!-- Address -->
        <div class="rounded-[var(--radius-xl)] border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
          <h2 class="font-bold text-[var(--color-text-base)] mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--color-unam-blue)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Contacto y sede
          </h2>
          <address class="not-italic text-sm text-[var(--color-text-muted)] leading-relaxed">
            Circuito Escolar 101, Planta baja<br />
            Ciudad Universitaria, Coyoacán<br />
            C.P. 04510, Ciudad de México
          </address>
        </div>
      </div>
    </div>
  </section>
</Site>
