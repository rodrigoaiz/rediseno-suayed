---
const navItems = [
  {
    label: 'Aprende en línea',
    href: '/aprende-en-linea',
    children: [
      { label: 'Comunidad PREMED', href: '/aprende-en-linea/premed' },
      { label: 'Ponte en Líne@', href: '/aprende-en-linea/ponte-en-linea' },
      { label: 'Asignaturas en línea', href: '/aprende-en-linea/asignaturas' },
      { label: 'Periodos intensivos', href: '/aprende-en-linea/periodos-intensivos' },
    ],
  },
  { label: 'FundamentaleSS', href: '/fundamentaless' },
  {
    label: 'Logra tu Meta',
    href: '/logra-tu-meta',
    children: [
      { label: 'Facultad de Medicina', href: '/logra-tu-meta/facultad' },
      { label: 'Escuelas Incorporadas', href: '/logra-tu-meta/incorporadas' },
    ],
  },
  { label: 'Normatividad', href: '/normatividad' },
  { label: 'Acerca de', href: '/acerca-de' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-[var(--color-bg)]/96 backdrop-blur-sm border-b border-[var(--color-border)]">
  <nav class="container-site flex items-center justify-between h-[4.25rem]">

    <!-- Wordmark -->
    <a href="/" class="flex flex-col leading-none group shrink-0">
      <img src="logsuayedw01.png" class="h-8 invert" alt="Logo de SUAYED" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-0.5">
      {navItems.map((item) => (
        <li class="relative group">
          <a
            href={item.href}
            class:list={[
              "relative flex items-center gap-1 px-3.5 py-2 text-sm font-medium transition-colors duration-150 rounded-[var(--radius-sm)]",
              isActive(item.href)
                ? "text-[var(--color-navy)]"
                : "text-[var(--color-text-mid)] hover:text-[var(--color-navy)]"
            ]}
          >
            {/* Active underline — gold */}
            {isActive(item.href) && (
              <span class="absolute bottom-0 left-3.5 right-3.5 h-[2px] bg-[var(--color-gold)] rounded-full" />
            )}
            {item.label}
            {item.children && (
              <svg
                class="w-3 h-3 opacity-40 group-hover:opacity-70 transition-transform duration-150 group-hover:rotate-180 shrink-0"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>

          {/* Dropdown */}
          {item.children && (
            <div class="absolute top-full left-0 mt-2 w-56 bg-[var(--color-bg)] rounded-[var(--radius-lg)] shadow-[var(--shadow-lg)] border border-[var(--color-border)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 translate-y-1 group-hover:translate-y-0">
              <ul class="p-1.5 space-y-0.5">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="flex items-center px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-text-mid)] hover:text-[var(--color-navy)] hover:bg-[var(--color-surface)] transition-colors duration-100"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-2">
      <a
        href="https://campus.facmed.unam.mx"
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-[var(--radius-md)] border border-[var(--color-border-strong)] text-sm font-semibold text-[var(--color-text-mid)] hover:border-[var(--color-navy)] hover:text-[var(--color-navy)] hover:bg-[var(--color-surface)] transition-all duration-150"
      >
        Campus virtual
        <svg class="w-3.5 h-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-[var(--radius-sm)] text-[var(--color-text-mid)] hover:bg-[var(--color-surface)] transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]">
    <ul class="container-site py-3 space-y-0.5">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex items-center px-3 py-2.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--color-text-mid)] hover:text-[var(--color-navy)] hover:bg-[var(--color-surface)] transition-colors"
          >
            {item.label}
          </a>
          {item.children && (
            <ul class="ml-4 mt-0.5 space-y-0.5">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="flex items-center px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-text-soft)] hover:text-[var(--color-navy)] hover:bg-[var(--color-surface)] transition-colors"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
      <li class="pt-2 pb-1">
        <a
          href="https://campus.facmed.unam.mx"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-navy)] text-[var(--color-bg)] text-sm font-semibold"
        >
          Campus virtual
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
