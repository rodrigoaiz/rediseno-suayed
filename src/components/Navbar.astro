---
const navItems = [
  {
    label: 'Aprende en línea',
    href: '/aprende-en-linea',
    children: [
      { label: 'Comunidad PREMED', href: '/aprende-en-linea/premed' },
      { label: 'Ponte en Líne@', href: '/aprende-en-linea/ponte-en-linea' },
      { label: 'Asignaturas en línea', href: '/aprende-en-linea/asignaturas' },
      { label: 'Periodos intensivos', href: '/aprende-en-linea/periodos-intensivos' },
    ],
  },
  { label: 'FundamentaleSS', href: '/fundamentaless' },
  {
    label: 'Logra tu Meta',
    href: '/logra-tu-meta',
    children: [
      { label: 'Facultad de Medicina', href: '/logra-tu-meta/facultad' },
      { label: 'Escuelas Incorporadas', href: '/logra-tu-meta/incorporadas' },
    ],
  },
  { label: 'Normatividad', href: '/normatividad' },
  { label: 'Acerca de', href: '/acerca-de' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[var(--color-border)] shadow-[0_1px_6px_rgba(0,63,138,0.07)]">
  <!-- Top bar institucional -->
  <div class="bg-[var(--color-unam-blue-dark)] text-white/80 text-xs">
    <div class="container-site flex items-center justify-between h-8">
      <span class="font-medium tracking-wide uppercase text-[0.65rem] text-white/60">
        Universidad Nacional Autónoma de México
      </span>
      <span class="hidden sm:block font-medium text-[0.65rem] text-white/60 tracking-wide uppercase">
        Facultad de Medicina
      </span>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="container-site flex items-center justify-between h-16">
    <!-- Logo / wordmark -->
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <div class="w-9 h-9 rounded-[var(--radius-md)] bg-[var(--color-unam-blue)] flex items-center justify-center shadow-sm group-hover:bg-[var(--color-unam-blue-mid)] transition-colors duration-200">
        <span class="text-white font-bold text-sm leading-none">S</span>
      </div>
      <div class="flex flex-col leading-tight">
        <span class="font-bold text-[var(--color-unam-blue)] text-base tracking-tight">SUAyED</span>
        <span class="text-[0.65rem] text-[var(--color-text-subtle)] font-medium -mt-0.5 hidden sm:block">Fac. Medicina · UNAM</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <li class="relative group">
          <a
            href={item.href}
            class:list={[
              "flex items-center gap-1 px-3 py-2 rounded-[var(--radius-sm)] text-sm font-medium transition-all duration-150",
              currentPath.startsWith(item.href) && item.href !== '/'
                ? "text-[var(--color-unam-blue)] bg-[var(--color-unam-blue-light)]"
                : "text-[var(--color-text-muted)] hover:text-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)]"
            ]}
          >
            {item.label}
            {item.children && (
              <svg class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 transition-transform duration-150 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>

          {item.children && (
            <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-[var(--radius-md)] shadow-[var(--shadow-card-hover)] border border-[var(--color-border)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 translate-y-1 group-hover:translate-y-0 z-50">
              <ul class="p-1.5">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="flex items-center px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-text-muted)] hover:text-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)] transition-colors duration-100"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-2">
      <a
        href="https://campus.facmed.unam.mx"
        target="_blank"
        rel="noopener"
        class="hidden sm:flex items-center gap-1.5 px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--color-unam-blue)] text-white text-sm font-semibold hover:bg-[var(--color-unam-blue-mid)] transition-colors duration-150 shadow-sm"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        Campus virtual
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-[var(--radius-sm)] text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-white">
    <ul class="container-site py-3 space-y-0.5">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex items-center justify-between px-3 py-2.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)] transition-colors"
          >
            {item.label}
          </a>
          {item.children && (
            <ul class="ml-4 mt-0.5 space-y-0.5">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="flex items-center px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-text-subtle)] hover:text-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)] transition-colors"
                  >
                    — {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
      <li class="pt-2 pb-1">
        <a
          href="https://campus.facmed.unam.mx"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-[var(--radius-sm)] bg-[var(--color-unam-blue)] text-white text-sm font-semibold"
        >
          Campus virtual
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
