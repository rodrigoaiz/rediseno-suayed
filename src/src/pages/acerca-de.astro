---
import Site from '../layouts/Site.astro';

const programs = [
  { name: 'Comunidad PREMED', tag: 'Aspirantes', href: '/aprende-en-linea/premed' },
  { name: 'Ponte en Líne@', tag: 'Estudiantes', href: '/aprende-en-linea/ponte-en-linea' },
  { name: 'Asignaturas Optativas a Distancia (MOLIMOD)', tag: 'Estudiantes', href: '/aprende-en-linea/asignaturas' },
  { name: 'FundamentaleSS', tag: 'Servicio social', href: '/fundamentaless' },
  { name: 'Logra tu Meta', tag: 'Egresados', href: '/logra-tu-meta/facultad' },
];

const timeline = [
  { year: '1970s', event: 'Fundación del Sistema Universidad Abierta (SUA) en la UNAM.' },
  { year: '2000s', event: 'Incorporación de la modalidad a distancia: el SUA se convierte en SUAyED.' },
  { year: '2010s', event: 'Lanzamiento de programas digitales: PREMED, Ponte en Líne@, MOLIMOD.' },
  { year: 'Hoy', event: 'Más de 45 años de trayectoria formando profesionales de la salud a distancia.' },
];
---

<Site
  title="Acerca de SUAyED FM | SUAyED"
  description="Conoce el Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina UNAM."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">Acerca de SUAyED FM</span>
      </nav>
      <p class="eyebrow mb-4">Institucional</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        Acerca de SUAyED FM
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        El Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina de la UNAM. Más de 45 años comprometidos con la educación médica accesible.
      </p>
    </div>
  </section>

  <!-- About + Timeline -->
  <section class="bg-[var(--color-surface)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20 lg:items-start">
      <div>
        <p class="eyebrow mb-5">¿Qué es el SUAyED FM?</p>
        <h2
          class="display text-[clamp(1.5rem,3vw,2.25rem)] text-[var(--color-navy)] leading-[1.08] mb-6"
          style="font-optical-sizing: auto;"
        >
          45 años formando profesionales de la salud
        </h2>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75] mb-4">
          En la Universidad Nacional Autónoma de México, desde hace más de <strong class="text-[var(--color-navy)] font-semibold">45 años</strong>, el SUAyED se ha comprometido con el desarrollo de proyectos y programas de formación a distancia que tienen como objetivo <strong class="text-[var(--color-navy)] font-semibold">ampliar la cobertura de educación superior</strong>.
        </p>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
          A la fecha, el Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina ofrece a sus estudiantes programas que apoyan su formación profesional en diferentes momentos de su trayectoria académica.
        </p>
      </div>

      <!-- Timeline -->
      <div>
        <p class="eyebrow mb-6">Trayectoria</p>
        <div class="relative pl-5 border-l border-[var(--color-border)] space-y-8">
          {timeline.map((item) => (
            <div class="relative">
              <div class="absolute -left-[1.4rem] w-2.5 h-2.5 rounded-full bg-[var(--color-bg)] border-2 border-[var(--color-gold-dark)] mt-0.5"></div>
              <div class="text-[0.625rem] font-bold tracking-[0.1em] uppercase text-[var(--color-gold-dark)] mb-1">{item.year}</div>
              <p class="text-[0.875rem] text-[var(--color-text-mid)] leading-relaxed">{item.event}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="bg-[var(--color-bg)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site">
      <p class="eyebrow mb-8">Programas que ofrece</p>
      <div class="border-t border-[var(--color-border)] max-w-3xl">
        {programs.map((prog) => (
          <a
            href={prog.href}
            class="group grid grid-cols-[7rem_1fr_1.5rem] gap-8 items-center py-5 border-b border-[var(--color-border)] hover:border-[var(--color-border-strong)] transition-colors duration-150"
          >
            <span class="text-[0.625rem] font-bold tracking-[0.1em] uppercase text-[var(--color-text-faint)] group-hover:text-[var(--color-gold-dark)] transition-colors leading-none">
              {prog.tag}
            </span>
            <span
              class="font-[family-name:var(--font-display)] font-semibold text-[1rem] text-[var(--color-navy)] leading-snug"
              style="font-optical-sizing: auto;"
            >
              {prog.name}
            </span>
            <svg class="w-3.5 h-3.5 text-[var(--color-text-faint)] group-hover:text-[var(--color-navy)] group-hover:translate-x-0.5 transition-all duration-150 shrink-0 justify-self-end" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Misión / Visión -->
  <section class="bg-[var(--color-surface)] py-16">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20">
      <div>
        <p class="text-[0.65rem] font-bold tracking-[0.12em] uppercase text-[var(--color-gold-dark)] mb-4">Misión</p>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
          Formar profesionales altamente calificados, éticos, críticos y humanistas, capaces de investigar y difundir el conocimiento para la solución de problemas de salud en beneficio del ser humano y de la nación.
        </p>
      </div>
      <div>
        <p class="text-[0.65rem] font-bold tracking-[0.12em] uppercase text-[var(--color-gold-dark)] mb-4">Visión</p>
        <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
          Estar a la vanguardia para ejercer el liderazgo en educación, investigación y difusión en salud y otras áreas científicas en beneficio del ser humano y de la nación.
        </p>
      </div>
    </div>
  </section>
</Site>
