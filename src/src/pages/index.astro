---
import Site from '../layouts/Site.astro';

const programs = [
  {
    icon: '🎓',
    title: 'Comunidad PREMED',
    desc: 'Diagnostica tus conocimientos del bachillerato antes de iniciar la licenciatura. Evalúa tu preparación académica de forma integral.',
    href: '/aprende-en-linea/premed',
    tag: 'Aspirantes',
    tagColor: 'bg-emerald-100 text-emerald-700',
  },
  {
    icon: '💻',
    title: 'Ponte en Líne@',
    desc: 'Refuerza tus aprendizajes con tutorías, seminarios y recursos educativos diseñados por la Facultad de Medicina.',
    href: '/aprende-en-linea/ponte-en-linea',
    tag: 'Estudiantes',
    tagColor: 'bg-blue-100 text-blue-700',
  },
  {
    icon: '📚',
    title: 'Asignaturas en línea',
    desc: '32 asignaturas optativas MOLIMOD disponibles a distancia con contenidos innovadores y a la vanguardia de la ciencia médica.',
    href: '/aprende-en-linea/asignaturas',
    tag: 'Estudiantes',
    tagColor: 'bg-blue-100 text-blue-700',
  },
  {
    icon: '⚡',
    title: 'Periodos intensivos',
    desc: 'Cursa asignaturas optativas en periodos de dos semanas. Ideal para estudiantes de 1° a 4° año de Médico Cirujano.',
    href: '/aprende-en-linea/periodos-intensivos',
    tag: 'Estudiantes',
    tagColor: 'bg-blue-100 text-blue-700',
  },
  {
    icon: '🏥',
    title: 'FundamentaleSS',
    desc: 'Libros electrónicos y recursos de apoyo para médicos pasantes en servicio social de la licenciatura de Médico Cirujano.',
    href: '/fundamentaless',
    tag: 'Servicio social',
    tagColor: 'bg-purple-100 text-purple-700',
  },
  {
    icon: '🏆',
    title: 'Logra tu Meta',
    desc: 'Exámenes de autoevaluación gratuitos para preparar el ENARM y orientar tu formación hacia una especialidad médica.',
    href: '/logra-tu-meta/facultad',
    tag: 'Egresados',
    tagColor: 'bg-amber-100 text-amber-700',
  },
];

const quickAccess = [
  { label: 'Soy aspirante', icon: '👤', href: '/aprende-en-linea/premed', desc: 'Evalúa tu preparación' },
  { label: 'Soy estudiante', icon: '🎒', href: '/aprende-en-linea/ponte-en-linea', desc: 'Accede a recursos' },
  { label: 'Servicio social', icon: '🩺', href: '/fundamentaless', desc: 'FundamentaleSS' },
  { label: 'Voy al ENARM', icon: '📋', href: '/logra-tu-meta/facultad', desc: 'Prepárate ahora' },
];

const stats = [
  { value: '45+', label: 'años de educación a distancia' },
  { value: '32', label: 'asignaturas MOLIMOD disponibles' },
  { value: '70', label: 'optativas en el sistema' },
  { value: '100%', label: 'programas gratuitos' },
];
---

<Site title="SUAyED | Facultad de Medicina UNAM" description="Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina, UNAM.">
  <!-- ── HERO ───────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-[var(--color-unam-blue-dark)] min-h-[580px] flex items-center">
    <!-- Background dot pattern -->
    <div class="absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;">
    </div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-unam-blue-dark)] via-[var(--color-unam-blue)] to-[#0066cc] opacity-90"></div>
    <!-- Gold accent top line -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-unam-gold)] via-[var(--color-unam-gold-light)] to-[var(--color-unam-gold)]"></div>

    <div class="container-site relative z-10 py-20 md:py-28">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 mb-6">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-unam-gold)]"></div>
          <span class="text-xs font-semibold text-white/80 tracking-wide uppercase">Sistema Universidad Abierta y Educación a Distancia</span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-[1.05] tracking-tight mb-6">
          Educación médica<br />
          <span class="text-[var(--color-unam-gold)]">a tu alcance</span>
        </h1>

        <p class="text-lg text-white/70 leading-relaxed max-w-xl mb-10">
          La Facultad de Medicina de la UNAM pone a tu disposición programas en línea para aprender, reforzar y avanzar en tu formación médica, sin importar en qué etapa te encuentres.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/aprende-en-linea"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--color-unam-gold)] text-[var(--color-unam-blue-dark)] font-bold text-sm hover:bg-[var(--color-unam-gold-dark)] transition-colors duration-150 shadow-lg">
            Explorar programas
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/acerca-de"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-white/10 border border-white/20 text-white font-semibold text-sm hover:bg-white/20 transition-colors duration-150">
            Acerca de SUAyED
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative circles -->
    <div class="absolute right-0 top-0 bottom-0 w-1/3 hidden xl:block overflow-hidden pointer-events-none">
      <div class="absolute right-[-80px] top-1/2 -translate-y-1/2 w-96 h-96 rounded-full border-[40px] border-white/5"></div>
      <div class="absolute right-16 top-1/2 -translate-y-1/2 w-48 h-48 rounded-full border-[20px] border-[var(--color-unam-gold)]/10"></div>
    </div>
  </section>

  <!-- ── QUICK ACCESS ─────────────────────────────────────── -->
  <section class="bg-white border-b border-[var(--color-border)]">
    <div class="container-site py-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-subtle)] mb-5 text-center">¿Cuál es tu perfil?</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {quickAccess.map((item) => (
          <a href={item.href}
            class="group flex flex-col items-center gap-2 p-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] hover:border-[var(--color-unam-blue)] hover:bg-[var(--color-unam-blue-light)] transition-all duration-150 text-center">
            <span class="text-2xl">{item.icon}</span>
            <span class="text-sm font-semibold text-[var(--color-text-base)] group-hover:text-[var(--color-unam-blue)] transition-colors leading-tight">{item.label}</span>
            <span class="text-xs text-[var(--color-text-subtle)]">{item.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── STATS ────────────────────────────────────────────── -->
  <section class="bg-[var(--color-surface)] border-b border-[var(--color-border)]">
    <div class="container-site py-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold text-[var(--color-unam-blue)] mb-1">{stat.value}</div>
            <div class="text-sm text-[var(--color-text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROGRAMS GRID ────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="container-site">
      <div class="text-center mb-14">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-unam-gold-dark)] mb-3">Oferta educativa</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-text-base)] tracking-tight mb-4">
          Programas y recursos en línea
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-xl mx-auto text-base leading-relaxed">
          Desde el diagnóstico inicial hasta la preparación para la especialidad. Todos los programas son gratuitos y accesibles.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {programs.map((prog) => (
          <a
            href={prog.href}
            class="group flex flex-col rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-white hover:border-[var(--color-unam-blue)] hover:shadow-[var(--shadow-card-hover)] transition-all duration-200 overflow-hidden"
          >
            <div class="h-1 bg-gradient-to-r from-[var(--color-unam-blue)] to-[var(--color-unam-blue-mid)] opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 rounded-[var(--radius-lg)] bg-[var(--color-unam-blue-light)] flex items-center justify-center text-2xl group-hover:bg-[var(--color-unam-blue)] transition-all duration-200">
                  {prog.icon}
                </div>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${prog.tagColor}`}>{prog.tag}</span>
              </div>
              <h3 class="font-bold text-[var(--color-text-base)] text-base mb-2 group-hover:text-[var(--color-unam-blue)] transition-colors">
                {prog.title}
              </h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
                {prog.desc}
              </p>
              <div class="flex items-center gap-1 mt-5 text-sm font-semibold text-[var(--color-unam-blue)] opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                Ver más
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── MISIÓN / VISIÓN ──────────────────────────────────── -->
  <section class="bg-[var(--color-surface)] py-20">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-unam-gold-dark)] mb-3">Facultad de Medicina · UNAM</p>
          <h2 class="text-3xl font-extrabold text-[var(--color-text-base)] tracking-tight mb-6 leading-tight">
            Formando profesionales<br />de la salud desde hace décadas
          </h2>
          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-[var(--radius-md)] bg-[var(--color-unam-blue-light)] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-[var(--color-unam-blue)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-[var(--color-text-base)] text-sm mb-1">Misión</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Formar profesionales altamente calificados, éticos, críticos y humanistas, capaces de investigar y difundir el conocimiento para la solución de problemas de salud en beneficio del ser humano y de la nación.
                </p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-[var(--radius-md)] bg-[var(--color-unam-gold-light)] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-[var(--color-unam-gold-dark)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-[var(--color-text-base)] text-sm mb-1">Visión</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Estar a la vanguardia para ejercer el liderazgo en educación, investigación y difusión en salud y otras áreas científicas en beneficio del ser humano y de la nación.
                </p>
              </div>
            </div>
          </div>
          <a href="/acerca-de"
            class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-unam-blue)] text-white text-sm font-semibold hover:bg-[var(--color-unam-blue-mid)] transition-colors">
            Conoce más sobre SUAyED
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Visual decoration -->
        <div class="relative hidden lg:flex items-center justify-center">
          <div class="relative w-80 h-80">
            <div class="absolute inset-0 rounded-full border-2 border-dashed border-[var(--color-border)]"
              style="animation: spin 30s linear infinite;">
            </div>
            <div class="absolute inset-10 rounded-full bg-[var(--color-unam-blue-light)] flex items-center justify-center">
              <div class="text-center px-4">
                <div class="text-5xl font-extrabold text-[var(--color-unam-blue)] mb-1">45+</div>
                <div class="text-xs font-medium text-[var(--color-text-muted)] leading-snug">años de educación<br/>a distancia</div>
              </div>
            </div>
            <div class="absolute -top-2 right-8 w-14 h-14 rounded-full bg-white border border-[var(--color-border)] shadow-[var(--shadow-card)] flex items-center justify-center text-xl">🎓</div>
            <div class="absolute bottom-4 -right-4 w-14 h-14 rounded-full bg-white border border-[var(--color-border)] shadow-[var(--shadow-card)] flex items-center justify-center text-xl">🏥</div>
            <div class="absolute -bottom-2 left-8 w-14 h-14 rounded-full bg-white border border-[var(--color-border)] shadow-[var(--shadow-card)] flex items-center justify-center text-xl">📚</div>
            <div class="absolute top-4 -left-4 w-14 h-14 rounded-full bg-white border border-[var(--color-border)] shadow-[var(--shadow-card)] flex items-center justify-center text-xl">💻</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ───────────────────────────────────────── -->
  <section class="bg-[var(--color-unam-blue)] py-16">
    <div class="container-site text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4 tracking-tight">
          ¿Listo para dar el siguiente paso?
        </h2>
        <p class="text-white/70 mb-8 text-base leading-relaxed">
          Accede al campus virtual de la Facultad de Medicina y conecta con todos los recursos educativos en línea.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="https://campus.facmed.unam.mx" target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--color-unam-gold)] text-[var(--color-unam-blue-dark)] font-bold text-sm hover:bg-[var(--color-unam-gold-dark)] transition-colors shadow-lg">
            Ir al campus virtual
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href="/normatividad"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-white/10 border border-white/20 text-white font-semibold text-sm hover:bg-white/20 transition-colors">
            Consultar normatividad
          </a>
        </div>
      </div>
    </div>
  </section>
</Site>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
