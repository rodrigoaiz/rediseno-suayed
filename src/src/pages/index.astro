---
import Site from '../layouts/Site.astro';

const programs = [
  {
    title: 'Comunidad PREMED',
    desc: 'Diagnostica tus conocimientos del bachillerato antes de iniciar la licenciatura.',
    href: '/aprende-en-linea/premed',
    tag: 'Aspirantes',
  },
  {
    title: 'Ponte en Líne@',
    desc: 'Refuerza tus aprendizajes con tutorías, seminarios y recursos educativos de la Facultad.',
    href: '/aprende-en-linea/ponte-en-linea',
    tag: 'Estudiantes',
  },
  {
    title: 'Asignaturas en línea',
    desc: '32 asignaturas optativas MOLIMOD a distancia con contenidos a la vanguardia de la ciencia médica.',
    href: '/aprende-en-linea/asignaturas',
    tag: 'Estudiantes',
  },
  {
    title: 'Periodos intensivos',
    desc: 'Cursa asignaturas optativas en periodos de dos semanas, para estudiantes de 1° a 4° año.',
    href: '/aprende-en-linea/periodos-intensivos',
    tag: 'Estudiantes',
  },
  {
    title: 'FundamentaleSS',
    desc: 'Libros electrónicos y recursos de apoyo para médicos pasantes en servicio social.',
    href: '/fundamentaless',
    tag: 'Servicio social',
  },
  {
    title: 'Logra tu Meta',
    desc: 'Exámenes de autoevaluación gratuitos para preparar el ENARM y orientarte hacia una especialidad.',
    href: '/logra-tu-meta/facultad',
    tag: 'Egresados',
  },
];

const profiles = [
  { label: 'Soy aspirante', href: '/aprende-en-linea/premed' },
  { label: 'Soy estudiante', href: '/aprende-en-linea/ponte-en-linea' },
  { label: 'Servicio social', href: '/fundamentaless' },
  { label: 'Voy al ENARM', href: '/logra-tu-meta/facultad' },
];

const stats = [
  { value: '45+', label: 'años de educación a distancia' },
  { value: '32', label: 'asignaturas MOLIMOD' },
  { value: '100%', label: 'programas gratuitos' },
];
---

<Site title="SUAyED | Facultad de Medicina UNAM">

  <!-- ═══════════════════════════════════════════════════════
       HERO — asimétrico, tipográfico, sin bloque de color
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg)] overflow-hidden border-b border-[var(--color-border)]">
    <div class="grid lg:grid-cols-[1fr_0.85fr] gap-0 items-stretch">

      <!-- Left: headline — padded like container -->
      <div class="flex flex-col justify-center py-20 lg:py-24 pl-[max(1.5rem,calc((100vw-1200px)/2+2.5rem))] pr-14 xl:pr-20 border-r-0 lg:border-r border-[var(--color-border)]">

        <p class="eyebrow mb-5">Facultad de Medicina · UNAM</p>

        <h1
          class="display text-[clamp(3rem,6vw,5.25rem)] text-[var(--color-navy)] leading-[1.01] tracking-[-0.03em] mb-6"
          style="font-optical-sizing: auto;"
        >
          Educación<br/>
          médica<br/>
          <em class="not-italic text-[var(--color-gold)]">a distancia</em>
        </h1>

        <span class="rule-gold mb-6"></span>

        <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[38ch] mb-8">
          Programas en línea para aprender, reforzar y avanzar en tu formación médica — sin importar en qué etapa te encuentres.
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <a
            href="/aprende-en-linea"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--color-navy)] text-[var(--color-bg)] text-sm font-semibold hover:bg-[var(--color-navy-mid)] transition-colors duration-150"
          >
            Ver programas
            <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/acerca-de"
            class="text-sm font-medium text-[var(--color-text-soft)] hover:text-[var(--color-navy)] transition-colors duration-150"
          >
            Acerca de SUAyED →
          </a>
        </div>
      </div>

      <!-- Right: editorial program index — surface tint, aligned to left column top padding -->
      <div class="hidden lg:flex flex-col justify-between pt-24 pb-10 px-12 bg-[var(--color-surface)]">
        <div>
          <p class="eyebrow mb-5 text-[var(--color-text-faint)]">Programas disponibles</p>
          <ul class="border-t border-[var(--color-border)]">
            {programs.map((prog) => (
              <li>
                <a
                  href={prog.href}
                  class="group flex items-baseline justify-between gap-5 py-[0.95rem] border-b border-[var(--color-border)] hover:border-[var(--color-border-strong)] transition-all duration-150"
                >
                  <span class="font-[family-name:var(--font-display)] font-semibold text-[0.9375rem] text-[var(--color-text-mid)] group-hover:text-[var(--color-navy)] transition-colors duration-150 leading-snug" style="font-optical-sizing: auto;">
                    {prog.title}
                  </span>
                  <span class="text-[0.625rem] font-bold tracking-[0.08em] uppercase text-[var(--color-text-faint)] group-hover:text-[var(--color-gold-dark)] transition-colors whitespace-nowrap shrink-0">
                    {prog.tag}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <!-- Campus access block -->
          <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
            <p class="text-[0.75rem] text-[var(--color-text-faint)] mb-3">Acceso directo</p>
            <a
              href="https://campus.facmed.unam.mx"
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 text-[0.875rem] font-semibold text-[var(--color-text-mid)] hover:text-[var(--color-navy)] transition-colors duration-150"
            >
              Campus virtual Fac. Medicina
              <svg class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        <p class="pt-6 text-[0.75rem] text-[var(--color-text-faint)]">
          Todos los programas son gratuitos y accesibles en línea.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PERFIL — strip de acceso rápido por usuario
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-surface)] border-y border-[var(--color-border)]">
    <div class="container-site py-5 flex flex-col sm:flex-row sm:items-center gap-4">
      <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-faint)] shrink-0">
        ¿Cuál es tu perfil?
      </span>
      <div class="flex flex-wrap gap-2">
        {profiles.map((p) => (
          <a
            href={p.href}
            class="inline-flex items-center px-4 py-1.5 rounded-full border border-[var(--color-border-strong)] text-sm font-medium text-[var(--color-text-mid)] hover:border-[var(--color-navy)] hover:text-[var(--color-navy)] hover:bg-[var(--color-navy-soft)] transition-all duration-150"
          >
            {p.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       STATS — números grandes, izquierda alineada, en fila
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg)] py-10 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row gap-8 sm:gap-0 sm:divide-x divide-[var(--color-border)]">
        {stats.map((s) => (
          <div class="sm:pr-12 sm:last:pr-0 sm:pl-12 sm:first:pl-0">
            <div
              class="display tabular text-[clamp(2rem,4vw,2.75rem)] text-[var(--color-navy)] leading-none mb-1 tracking-[-0.02em]"
              style="font-optical-sizing: auto;"
            >
              {s.value}
            </div>
            <div class="text-[0.78125rem] text-[var(--color-text-soft)] leading-snug max-w-[15ch] mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PROGRAMAS — lista asimétrica (no grid de tarjetas)
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-surface)] py-16 border-t border-[var(--color-border)]">
    <div class="container-site">

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
        <div>
          <p class="eyebrow mb-3">Oferta educativa</p>
          <h2
            class="display text-[clamp(1.75rem,3.5vw,2.5rem)] text-[var(--color-navy)]"
            style="font-optical-sizing: auto;"
          >
            Programas y recursos en línea
          </h2>
        </div>
        <a
          href="/aprende-en-linea"
          class="text-sm font-medium text-[var(--color-text-soft)] hover:text-[var(--color-navy)] transition-colors duration-150 whitespace-nowrap shrink-0"
        >
          Ver todos →
        </a>
      </div>

      <div class="border-t border-[var(--color-border)]">
        {programs.map((prog) => (
          <a
            href={prog.href}
            class="group grid grid-cols-1 md:grid-cols-[7rem_1fr_1.5rem] gap-3 md:gap-8 items-center py-5 border-b border-[var(--color-border)] hover:border-[var(--color-border-strong)] transition-colors duration-150"
          >
            <span class="text-[0.625rem] font-bold tracking-[0.1em] uppercase text-[var(--color-text-faint)] group-hover:text-[var(--color-gold-dark)] transition-colors leading-none">
              {prog.tag}
            </span>
            <div>
              <h3 class="font-[family-name:var(--font-display)] font-semibold text-[1.0625rem] text-[var(--color-navy)] leading-snug mb-0.5 transition-colors" style="font-optical-sizing: auto;">
                {prog.title}
              </h3>
              <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">
                {prog.desc}
              </p>
            </div>
            <svg class="hidden md:block w-3.5 h-3.5 text-[var(--color-text-faint)] group-hover:text-[var(--color-navy)] group-hover:translate-x-0.5 transition-all duration-150 shrink-0 justify-self-end" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       MISIÓN — texto puro, sin cajas de ícono
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg)] py-20 border-t border-[var(--color-border)]">
    <div class="container-site grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-20 lg:items-start">

      <div class="flex flex-col gap-8">
        <div>
          <p class="eyebrow mb-5">Facultad de Medicina · UNAM</p>
          <h2
            class="display text-[clamp(1.75rem,3.5vw,2.5rem)] text-[var(--color-navy)] leading-[1.08]"
            style="font-optical-sizing: auto;"
          >
            Formando profesionales<br/>de la salud
          </h2>
        </div>
        <p class="text-[0.9375rem] text-[var(--color-text-soft)] leading-[1.75] max-w-[38ch]">
          El Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina de la UNAM lleva más de 45 años formando profesionales de la salud.
        </p>
        <a
          href="/acerca-de"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-md)] border border-[var(--color-navy)] text-[var(--color-navy)] text-sm font-semibold hover:bg-[var(--color-navy)] hover:text-[var(--color-bg)] transition-all duration-150 self-start"
        >
          Conoce SUAyED
          <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="space-y-9 lg:pt-2">
        <div>
          <h3 class="text-[0.65rem] font-bold tracking-[0.12em] uppercase text-[var(--color-gold-dark)] mb-3">
            Misión
          </h3>
          <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
            Formar profesionales altamente calificados, éticos, críticos y humanistas, capaces de investigar y difundir el conocimiento para la solución de problemas de salud en beneficio del ser humano y de la nación.
          </p>
        </div>
        <div>
          <h3 class="text-[0.65rem] font-bold tracking-[0.12em] uppercase text-[var(--color-gold-dark)] mb-3">
            Visión
          </h3>
          <p class="text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
            Estar a la vanguardia para ejercer el liderazgo en educación, investigación y difusión en salud y otras áreas científicas en beneficio del ser humano y de la nación.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CTA final — una línea, limpio
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-[var(--color-navy)] py-12">
    <div class="container-site flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="font-[family-name:var(--font-display)] font-semibold text-[1.375rem] text-[var(--color-bg)] leading-snug" style="font-optical-sizing: auto;">
          ¿Listo para dar el siguiente paso?
        </p>
        <p class="text-[0.8125rem] text-[oklch(74%_0.02_255)] mt-1">
          Accede al campus virtual de la Facultad de Medicina.
        </p>
      </div>
      <a
        href="https://campus.facmed.unam.mx"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--color-gold)] text-[var(--color-navy)] font-bold text-sm hover:bg-[var(--color-gold-dark)] transition-colors duration-150 shrink-0"
      >
        Ir al campus virtual
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </section>

</Site>
