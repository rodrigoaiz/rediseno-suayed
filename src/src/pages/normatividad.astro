---
import Site from '../layouts/Site.astro';

const docs = [
  {
    title: 'Lineamientos para el desarrollo del MOLIMOD',
    desc: 'Normativa que regula el funcionamiento y operación de las asignaturas optativas en modalidad a distancia.',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Reglamento General de Inscripciones',
    desc: 'Normas generales para la inscripción y reinscripción de alumnos en la UNAM.',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Estatuto General de la UNAM',
    desc: 'Marco normativo fundamental que rige la organización y funcionamiento de la Universidad.',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
  {
    title: 'Plan de Estudios de Medicina',
    desc: 'Estructura curricular y plan de estudios vigente de la licenciatura de Médico Cirujano.',
    href: 'https://suayed.facmed.unam.mx/index.php/normatividad/',
  },
];
---

<Site
  title="Normatividad | SUAyED"
  description="Lineamientos, procedimientos y documentos normativos del SUAyED Facultad de Medicina UNAM."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-site py-10 lg:py-12">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-faint)] mb-8">
        <a href="/" class="hover:text-[var(--color-navy)] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-[var(--color-text-soft)]">Normatividad</span>
      </nav>
      <p class="eyebrow mb-4">Documentos oficiales</p>
      <h1
        class="display text-[clamp(2.25rem,5vw,3.75rem)] text-[var(--color-navy)] leading-[1.04] tracking-[-0.025em] mb-5"
        style="font-optical-sizing: auto;"
      >
        Normatividad
      </h1>
      <p class="text-[var(--color-text-mid)] text-[1rem] leading-[1.75] max-w-[58ch]">
        Lineamientos, procedimientos y documentos normativos que rigen el funcionamiento del SUAyED y los programas educativos de la Facultad de Medicina UNAM.
      </p>
    </div>
  </section>

  <!-- Documents list -->
  <section class="bg-[var(--color-surface)] py-16 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="max-w-3xl">
        <p class="eyebrow mb-8">Documentos disponibles</p>
        <div class="border-t border-[var(--color-border)]">
          {docs.map((doc) => (
            <a
              href={doc.href}
              target="_blank"
              rel="noopener"
              class="group grid grid-cols-1 md:grid-cols-[1fr_1.5rem] gap-4 items-center py-5 border-b border-[var(--color-border)] hover:border-[var(--color-border-strong)] transition-colors duration-150"
            >
              <div>
                <h2
                  class="font-[family-name:var(--font-display)] font-semibold text-[1rem] text-[var(--color-navy)] leading-snug mb-1 group-hover:text-[var(--color-navy-mid)] transition-colors"
                  style="font-optical-sizing: auto;"
                >
                  {doc.title}
                </h2>
                <p class="text-[0.8125rem] text-[var(--color-text-soft)] leading-relaxed">{doc.desc}</p>
              </div>
              <svg class="hidden md:block w-4 h-4 text-[var(--color-text-faint)] group-hover:text-[var(--color-navy)] transition-colors justify-self-end shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Address -->
  <section class="bg-[var(--color-bg)] py-12 border-b border-[var(--color-border)]">
    <div class="container-site">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">Sede</p>
        <address class="not-italic text-[0.9375rem] text-[var(--color-text-mid)] leading-[1.75]">
          Circuito Escolar 101, Planta baja<br />
          Ciudad Universitaria, Coyoacán<br />
          C.P. 04510, Ciudad de México
        </address>
      </div>
    </div>
  </section>
</Site>
