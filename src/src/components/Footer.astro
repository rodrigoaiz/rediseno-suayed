---
const links = [
  {
    group: 'Aprende en línea',
    items: [
      { label: 'Comunidad PREMED', href: '/aprende-en-linea/premed' },
      { label: 'Ponte en Líne@', href: '/aprende-en-linea/ponte-en-linea' },
      { label: 'Asignaturas en línea', href: '/aprende-en-linea/asignaturas' },
      { label: 'Periodos intensivos', href: '/aprende-en-linea/periodos-intensivos' },
    ],
  },
  {
    group: 'Institucional',
    items: [
      { label: 'Acerca de SUAyED FM', href: '/acerca-de' },
      { label: 'Normatividad', href: '/normatividad' },
      { label: 'FundamentaleSS', href: '/fundamentaless' },
    ],
  },
  {
    group: 'Logra tu Meta',
    items: [
      { label: 'Facultad de Medicina', href: '/logra-tu-meta/facultad' },
      { label: 'Escuelas Incorporadas', href: '/logra-tu-meta/incorporadas' },
    ],
  },
];
---

<footer class="bg-[var(--color-unam-blue-dark)] text-white mt-24">
  <!-- Main footer -->
  <div class="container-site py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-[var(--radius-md)] bg-white/10 flex items-center justify-center">
            <span class="text-white font-bold text-sm">S</span>
          </div>
          <div>
            <div class="font-bold text-base text-white">SUAyED</div>
            <div class="text-xs text-white/50 -mt-0.5">Fac. Medicina · UNAM</div>
          </div>
        </div>
        <p class="text-sm text-white/60 leading-relaxed max-w-xs">
          Sistema Universidad Abierta y Educación a Distancia de la Facultad de Medicina de la UNAM. Más de 45 años formando profesionales de la salud.
        </p>
        <div class="flex items-center gap-2 mt-6">
          <a href="https://www.facebook.com" target="_blank" rel="noopener" aria-label="Facebook"
            class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="Twitter / X"
            class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M4 4l16 16M4 20L20 4"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M4 4l16 16M4 20L20 4"/></svg>
          </a>
          <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube"
            class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.54C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      {links.map((group) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-unam-gold)] mb-4">{group.group}</h3>
          <ul class="space-y-2.5">
            {group.items.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/60 hover:text-white transition-colors duration-150">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Contacto -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-unam-gold)] mb-4">Contacto</h3>
        <address class="not-italic space-y-3">
          <p class="text-sm text-white/60 leading-relaxed">
            Circuito Escolar 101, Planta baja<br />
            Ciudad Universitaria, Coyoacán<br />
            C.P. 04510, CDMX
          </p>
          <a href="mailto:suayed@facmed.unam.mx" class="text-sm text-white/60 hover:text-white transition-colors block">
            suayed@facmed.unam.mx
          </a>
          <a href="https://campus.facmed.unam.mx" target="_blank" rel="noopener"
            class="inline-flex items-center gap-1.5 mt-2 px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--color-unam-gold)] text-[var(--color-unam-blue-dark)] text-sm font-semibold hover:bg-[var(--color-unam-gold-dark)] transition-colors">
            Campus virtual
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-site flex flex-col sm:flex-row items-center justify-between gap-2 py-5">
      <p class="text-xs text-white/40">
        © {new Date().getFullYear()} SUAyED · Facultad de Medicina · UNAM. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a href="/normatividad" class="text-xs text-white/40 hover:text-white/70 transition-colors">Aviso de privacidad</a>
        <a href="https://www.unam.mx" target="_blank" rel="noopener" class="text-xs text-white/40 hover:text-white/70 transition-colors">unam.mx</a>
      </div>
    </div>
  </div>
</footer>
