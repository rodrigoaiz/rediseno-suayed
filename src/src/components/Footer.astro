---
const links = [
  {
    group: 'Aprende en línea',
    items: [
      { label: 'Comunidad PREMED', href: '/aprende-en-linea/premed' },
      { label: 'Ponte en Líne@', href: '/aprende-en-linea/ponte-en-linea' },
      { label: 'Asignaturas en línea', href: '/aprende-en-linea/asignaturas' },
      { label: 'Periodos intensivos', href: '/aprende-en-linea/periodos-intensivos' },
    ],
  },
  {
    group: 'Institucional',
    items: [
      { label: 'Acerca de SUAyED FM', href: '/acerca-de' },
      { label: 'Normatividad', href: '/normatividad' },
      { label: 'FundamentaleSS', href: '/fundamentaless' },
    ],
  },
  {
    group: 'Logra tu Meta',
    items: [
      { label: 'Facultad de Medicina', href: '/logra-tu-meta/facultad' },
      { label: 'Escuelas Incorporadas', href: '/logra-tu-meta/incorporadas' },
    ],
  },
];
---

<footer class="bg-[var(--color-navy)] text-[var(--color-bg)]">
  <div class="container-site pt-14 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10">

      <!-- Brand col -->
      <div>
        <a href="/" class="inline-block mb-5">
          <span class="font-[family-name:var(--font-display)] font-bold text-[1.375rem] tracking-tight text-[var(--color-bg)] leading-none">
            SUAyED
          </span>
          <span class="block text-[0.6rem] font-semibold tracking-[0.1em] uppercase text-[oklch(74%_0.02_255)] mt-0.5">
            Fac. Medicina · UNAM
          </span>
        </a>

        <p class="text-sm leading-relaxed text-[oklch(74%_0.02_255)] max-w-[22ch]">
          Sistema Universidad Abierta y Educación a Distancia.<br/>
          Más de 45 años formando profesionales de la salud.
        </p>

        <div class="mt-7 flex items-center gap-1.5">
          <a
            href="https://campus.facmed.unam.mx"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[var(--radius-md)] bg-[var(--color-gold)] text-[var(--color-navy)] text-sm font-semibold hover:bg-[var(--color-gold-dark)] transition-colors duration-150"
          >
            Campus virtual
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav groups -->
      {links.map((group) => (
        <div>
          <h3 class="eyebrow text-[var(--color-gold)] mb-4">{group.group}</h3>
          <ul class="space-y-2.5">
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-[oklch(74%_0.02_255)] hover:text-[var(--color-bg)] transition-colors duration-150"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider + bottom -->
    <div class="mt-12 pt-6 border-t border-[oklch(35%_0.04_255)] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs text-[oklch(55%_0.03_255)]">
        © {new Date().getFullYear()} SUAyED · Facultad de Medicina · UNAM
      </p>
      <div class="flex items-center gap-5">
        <a href="/normatividad" class="text-xs text-[oklch(55%_0.03_255)] hover:text-[oklch(74%_0.02_255)] transition-colors">
          Aviso de privacidad
        </a>
        <a href="https://www.unam.mx" target="_blank" rel="noopener" class="text-xs text-[oklch(55%_0.03_255)] hover:text-[oklch(74%_0.02_255)] transition-colors">
          unam.mx
        </a>
        <a href="mailto:suayed@facmed.unam.mx" class="text-xs text-[oklch(55%_0.03_255)] hover:text-[oklch(74%_0.02_255)] transition-colors">
          suayed@facmed.unam.mx
        </a>
      </div>
    </div>
  </div>
</footer>
